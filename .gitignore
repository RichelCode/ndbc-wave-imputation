# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.ipynb_checkpoints/
*.egg-info/

# Data — don't commit raw or processed NDBC files (too large, reproducible from code)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Figures — keep source code that generates them, not necessarily the outputs
# (remove this line if you want figures tracked)
figures/*.png
figures/*.pdf
!figures/.gitkeep

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Secrets
.env
*.key

# Diagnostic 10 outputs — keep these in version control (publication artifacts)
!data/processed/d10_results.json
!data/processed/d10_config.yaml
!figures/d10_*.png

# Baseline figures — keep these in version control (publication artifacts)
!figures/baseline_*.png
!figures/baseline_*.pdf
!figures/baseline_*.txt

# Baseline results — keep these in version control (publication artifacts)
!data/processed/baseline_*_results.json
!data/processed/baseline_significance.json
